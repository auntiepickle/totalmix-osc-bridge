{
  "macros": {
    "an12_to_aes_send": {
      "description": "Hardware Input AN 1/2 → AES Hardware Output send",
      "workspace": "Pill_setup",
      "snapshot": "reset",
      "force_switch": true,
      "steps": [
        { "osc": "/setSubmix", "value": 12.0 },
        { "osc": "/1/volume1", "value": "{{param}}" }
      ],
      "midi_triggers": [
        {
          "type": "control_change",
          "number": 42,
          "channel": 1,
          "use_value_as_param": true
        }
      ],
      "param_range": [0.0, 1.0]
    }
  }
}
{
  "macros": {
    "an3_to_adat1_send": {
      "description": "Hardware Input AN 3 → ADAT 1 output send (native ramp)",
      "workspace": "Pill_setup",
      "snapshot": "lastthingidid",
      "force_switch": false,
      "steps": [
        { "osc": "/setSubmix", "value": 14.0 },
        {
          "osc": "/1/volume2",
          "value": "{{param}}",
          "operation": {
            "type": "ramp",
            "bars": 2,
            "bpm": 140
          }
        }
      ],
      "midi_triggers": [
        { "type": "control_change", "number": 44, "channel": 1, "use_value_as_param": true }
      ],
      "routing_label": "AN 3 → ADAT 1"
    },

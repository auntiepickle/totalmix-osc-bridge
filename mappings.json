{
  "macros": {
    "an12_to_aes_send": {
      "description": "Hardware Input AN 1/2 → AES Hardware Output send",
      "workspace": "Pill_setup",
      "snapshot": "reset",
      "steps": [
        { "osc": "/setSubmix", "value": 12.0 },
        { "osc": "/1/volume1", "value": "{{param}}" }
      ],
      "midi_triggers": [
        {
          "type": "note_on",
          "number": 60,
          "channel": 1,
          "use_velocity_as_param": true
        },
        {
          "type": "control_change",
          "number": 20,
          "channel": 1
        }
      ],
      "mqtt_topic": "studio/totalmix/an12_aes_send",
      "param_range": [0.0, 1.0]
    }
  }
}
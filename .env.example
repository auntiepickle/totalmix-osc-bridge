# ================================================
# TotalMix OSC Bridge Environment Variables
# Copy to .env and edit as needed
# ================================================

# RME UFX II OSC (TotalMix)
OSC_IP=192.168.1.50
OSC_PORT=9001

# MQTT (Mosquitto)
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=your_mqtt_user
MQTT_PASS=your_mqtt_password

# Web Client v1 (FastAPI UI)
WEB_PORT=8088          # ← CHANGE THIS IF NEEDED (single source of truth)

# Optional flags
ENABLE_OSC_MONITOR=true